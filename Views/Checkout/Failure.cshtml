@{
    ViewData["Title"] = "Échec de la transaction";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-x-circle text-danger" style="font-size:3rem;"></i>
                    </div>
                    <h2 class="mb-3">Paiement refusé</h2>
                    <p class="text-muted mb-4">
                        @ViewBag.ErrorMessage
                    </p>

                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-cart3 me-1"></i>Retour au panier
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-house-door me-1"></i>Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

